  <!-- For more information on Entity Framework configuration, visit http://go.microsoft.com/fwlink/?LinkID=237468 --></configSections>
  <connectionStrings>
    <add name="defaultSQLServer" connectionString="Data Source=[PALVELIN];Initial Catalog=[TIETOKANTA];Integrated Security=False;user id=[TIETOKANTAKÄYTTÄJÄ];pwd=[SALASANA];MultipleActiveResultSets=True;Packet Size=4096;Application Name=&quot;Microsoft SQL Server Management Studio&quot;" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <!-- Sharepoint-tunnukset -->
    <add key="ServiceTunnus" value="" />
    <add key="ServiceTunnusSalasana" value="" />
    <add key="ServiceTunnusDomain" value="" />
    <!-- Sopimusarkisto -->
    <add key="SopimusarkistoListaId" value="{57CCF427-16A5-46A1-9F0F-F370FBF51E78}" />
    <add key="SopimusarkistoNakymaId" value="{C9FCD043-2F18-4782-9A09-25F1E7BA9EDE}" />
    <add key="SopimusarkistoIntegraatioPaalla" value="false" />
    <add key="SopimusarkistoUrl" value="" />
    <add key="SopimusarkistoHeratysUrl" value="" />
    <!-- Sopimusarkisto (levy) -->
    <add key="SopimusarkistoPolku" value="C:\Temp\sopimusarkisto" />
    <add key="SopimusarkistoPolkuUudet" value="C:\Temp\sopimusarkisto\uudet" />  
    <!-- Raportointi -->
    <add key="TiedostoraporttiPolku" value="C:\Temp\sopimusarkisto\raportti.csv" />
    <!-- Haku -->
    <add key="MaxSiirtoMaara" value="2"/>
