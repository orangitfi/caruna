  </system.diagnostics>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
  </startup>
  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="SopimusArkistoSP" maxReceivedMessageSize="200000">
          <security mode="TransportCredentialOnly">
            <transport clientCredentialType="Ntlm" proxyCredentialType="None" realm="" />
          </security>
        </binding>
      </basicHttpBinding>
    </bindings>
    <client>
      <endpoint address="http://intranet/OPO/_vti_bin/Lists.asmx" binding="basicHttpBinding" bindingConfiguration="SopimusArkistoSP" contract="SopimusarkistoLists.ListsSoap" name="ListsSoap" />
      <endpoint address="http://intranet/OPO/_vti_bin/Views.asmx" binding="basicHttpBinding" bindingConfiguration="SopimusArkistoSP" contract="SopimusarkistoViews.ViewsSoap" name="ViewsSoap" />
    </client>
  </system.serviceModel>
  <entityFramework>
    <defaultConnectionFactory type="System.Data.Entity.Infrastructure.LocalDbConnectionFactory, EntityFramework">
      <parameters>
        <parameter value="v11.0" />
      </parameters>
    </defaultConnectionFactory>
    <providers>
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
    </providers>
  </entityFramework>
</configuration>